# Ghostty config - GitHub Dark theme
# Font settings
font-family = "SF Mono"
font-size = 12
font-thicken = true

# Cursor - block style
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

# Colors - Dark Transparent Theme (Stock-like)
background = #171717
background-opacity = 0.85
background-blur = true
foreground = #ececec
bold-color = #ffffff
cursor-color = #4d4d4d
selection-background = #414141
selection-foreground = #ffffff

# ANSI color palette (0-15) - Stock macOS Terminal
# Normal colors
palette = 0=#000000
palette = 1=#c23621
palette = 2=#25bc24
palette = 3=#adad27
palette = 4=#492ee1
palette = 5=#d338d3
palette = 6=#33bbc8
palette = 7=#cbcccb

# Bright colors
palette = 8=#818383
palette = 9=#fc391f
palette = 10=#31e722
palette = 11=#eaec23
palette = 12=#5833ff
palette = 13=#f935f8
palette = 14=#14f0f3
palette = 15=#ffffff

# Use Option as Meta key
macos-option-as-alt = true

# Remove window padding gaps
window-padding-x = 0
window-padding-y = 0
window-padding-balance = true
window-padding-color = extend
