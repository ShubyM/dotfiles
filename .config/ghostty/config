# Ghostty config - Pigeon Frost theme
# Font settings
font-family = "SF Mono"
font-size = 12
font-thicken = true

# Cursor - block style
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

# Colors - Pigeon Frost theme
background = #171717
background-opacity = 0.72
background-blur = true
foreground = #d8d3c8
bold-color = #ebe6dc
cursor-color = #d6a84f
selection-background = #3a3248
selection-foreground = #ebe6dc

# ANSI color palette (0-15) - pigeon body, neck, and foot accents
# Normal colors
palette = 0=#111315
palette = 1=#d97868
palette = 2=#2fbf9f
palette = 3=#d6a84f
palette = 4=#53616b
palette = 5=#7d5ac7
palette = 6=#1f8f9a
palette = 7=#d8d3c8

# Bright colors
palette = 8=#7d858c
palette = 9=#e58b7d
palette = 10=#6fd8bd
palette = 11=#e3c36f
palette = 12=#7f95a3
palette = 13=#b58cff
palette = 14=#56c5cf
palette = 15=#ebe6dc

# Use Option as Meta key
macos-option-as-alt = true

# Keep content aligned inside the rounded macOS window edge
window-padding-x = 6
window-padding-y = 4
window-padding-balance = true
window-padding-color = extend
