{
  "$schema": "vscode://schemas/color-theme",
  "name": "Pigeon Frost",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "focusBorder": "#7558a8",
    "foreground": "#ded8cf",
    "descriptionForeground": "#a4adb2",
    "errorForeground": "#cf8176",
    "icon.foreground": "#a4adb2",
    "sash.hoverBorder": "#53616b",
    "selection.background": "#2f353a",
    "textLink.foreground": "#58aeba",
    "textLink.activeForeground": "#a381d6",
    "textBlockQuote.background": "#1f1f1f",
    "textBlockQuote.border": "#53616b",
    "textCodeBlock.background": "#1f1f1f",
    "button.background": "#53616b",
    "button.foreground": "#d8d3ca",
    "button.hoverBackground": "#7f95a3",
    "dropdown.background": "#1f1f1f",
    "dropdown.border": "#2f353a",
    "dropdown.foreground": "#ded8cf",
    "input.background": "#1f1f1f",
    "input.border": "#2f353a",
    "input.foreground": "#ded8cf",
    "input.placeholderForeground": "#7d858c",
    "badge.background": "#53616b",
    "badge.foreground": "#d8d3ca",
    "progressBar.background": "#58aeba",
    "titleBar.activeBackground": "#1f1f1f",
    "titleBar.activeForeground": "#d8d3ca",
    "titleBar.inactiveBackground": "#1f1f1f",
    "titleBar.inactiveForeground": "#7d858c",
    "activityBar.background": "#1f1f1f",
    "activityBar.foreground": "#ded8cf",
    "activityBar.inactiveForeground": "#7d858c",
    "activityBarBadge.background": "#7558a8",
    "activityBarBadge.foreground": "#161819",
    "sideBar.background": "#1f1f1f",
    "sideBar.foreground": "#ded8cf",
    "sideBar.border": "#2f353a",
    "sideBarTitle.foreground": "#d8d3ca",
    "sideBarSectionHeader.background": "#1f1f1f",
    "sideBarSectionHeader.foreground": "#a4adb2",
    "list.activeSelectionBackground": "#273237",
    "list.activeSelectionForeground": "#d8d3ca",
    "list.inactiveSelectionBackground": "#2f353a",
    "list.inactiveSelectionForeground": "#ded8cf",
    "list.hoverBackground": "#2f353a",
    "list.focusOutline": "#53616b",
    "list.highlightForeground": "#58aeba",
    "tree.indentGuidesStroke": "#2f353a",
    "editor.background": "#1f1f1f",
    "editor.foreground": "#ded8cf",
    "editorLineNumber.foreground": "#53616b",
    "editorLineNumber.activeForeground": "#7f95a3",
    "editorCursor.foreground": "#ded8cf",
    "editor.selectionBackground": "#2f353a",
    "editor.inactiveSelectionBackground": "#2f353a",
    "editor.selectionHighlightBackground": "#58aeba22",
    "editor.wordHighlightBackground": "#58aeba22",
    "editor.wordHighlightStrongBackground": "#a381d633",
    "editor.findMatchBackground": "#c9ad6855",
    "editor.findMatchHighlightBackground": "#7558a844",
    "editor.findRangeHighlightBackground": "#273237",
    "editor.hoverHighlightBackground": "#58aeba22",
    "editor.lineHighlightBackground": "#ffffff06",
    "editorLineNumber.dimmedForeground": "#2f353a",
    "editorWhitespace.foreground": "#2f353a",
    "editorIndentGuide.background1": "#2f353a",
    "editorIndentGuide.activeBackground1": "#53616b",
    "editorRuler.foreground": "#2f353a",
    "editorCodeLens.foreground": "#7d858c",
    "editorBracketMatch.background": "#7558a833",
    "editorBracketMatch.border": "#a381d6",
    "editorBracketHighlight.foreground1": "#a381d6",
    "editorBracketHighlight.foreground2": "#65bfa9",
    "editorBracketHighlight.foreground3": "#c9ad68",
    "editorBracketHighlight.foreground4": "#58aeba",
    "editorBracketHighlight.foreground5": "#7f95a3",
    "editorGutter.background": "#1f1f1f",
    "editorGutter.modifiedBackground": "#c9ad68",
    "editorGutter.addedBackground": "#58aeba",
    "editorGutter.deletedBackground": "#cf8176",
    "editorError.foreground": "#cf8176",
    "editorWarning.foreground": "#c9ad68",
    "editorInfo.foreground": "#36818a",
    "editorHint.foreground": "#65bfa9",
    "editorOverviewRuler.border": "#1f1f1f",
    "editorOverviewRuler.errorForeground": "#cf8176",
    "editorOverviewRuler.warningForeground": "#c9ad68",
    "editorOverviewRuler.infoForeground": "#36818a",
    "editorGroupHeader.tabsBackground": "#1f1f1f",
    "editorGroup.border": "#2f353a",
    "tab.activeBackground": "#1f1f1f",
    "tab.activeForeground": "#d8d3ca",
    "tab.inactiveBackground": "#1f1f1f",
    "tab.inactiveForeground": "#7d858c",
    "tab.hoverForeground": "#d8d3ca",
    "tab.border": "#1f1f1f",
    "tab.activeBorderTop": "#7558a8",
    "breadcrumb.background": "#1f1f1f",
    "breadcrumb.foreground": "#7d858c",
    "breadcrumb.focusForeground": "#d8d3ca",
    "breadcrumb.activeSelectionForeground": "#a381d6",
    "panel.background": "#1f1f1f",
    "panel.border": "#2f353a",
    "panelTitle.activeForeground": "#d8d3ca",
    "panelTitle.inactiveForeground": "#7d858c",
    "panelTitle.activeBorder": "#7558a8",
    "terminal.background": "#1f1f1f",
    "terminal.foreground": "#ded8cf",
    "terminal.ansiBlack": "#161819",
    "terminal.ansiRed": "#cf8176",
    "terminal.ansiGreen": "#65bfa9",
    "terminal.ansiYellow": "#c9ad68",
    "terminal.ansiBlue": "#53616b",
    "terminal.ansiMagenta": "#7558a8",
    "terminal.ansiCyan": "#36818a",
    "terminal.ansiWhite": "#ded8cf",
    "terminal.ansiBrightBlack": "#7d858c",
    "terminal.ansiBrightRed": "#cf8176",
    "terminal.ansiBrightGreen": "#65bfa9",
    "terminal.ansiBrightYellow": "#c9ad68",
    "terminal.ansiBrightBlue": "#7f95a3",
    "terminal.ansiBrightMagenta": "#a381d6",
    "terminal.ansiBrightCyan": "#58aeba",
    "terminal.ansiBrightWhite": "#d8d3ca",
    "statusBar.background": "#1f1f1f",
    "statusBar.foreground": "#ded8cf",
    "statusBar.border": "#2f353a",
    "statusBar.noFolderBackground": "#1f1f1f",
    "statusBar.debuggingBackground": "#53616b",
    "statusBarItem.remoteBackground": "#53616b",
    "statusBarItem.remoteForeground": "#d8d3ca",
    "statusBarItem.hoverBackground": "#2f353a",
    "menu.background": "#1f1f1f",
    "menu.foreground": "#ded8cf",
    "menu.selectionBackground": "#273237",
    "menu.selectionForeground": "#d8d3ca",
    "menu.separatorBackground": "#2f353a",
    "quickInput.background": "#1f1f1f",
    "quickInput.foreground": "#ded8cf",
    "quickInputList.focusBackground": "#273237",
    "peekView.border": "#7558a8",
    "peekViewEditor.background": "#1f1f1f",
    "peekViewResult.background": "#1f1f1f",
    "peekViewResult.selectionBackground": "#273237",
    "peekViewTitle.background": "#1f1f1f",
    "diffEditor.insertedTextBackground": "#65bfa922",
    "diffEditor.removedTextBackground": "#cf817622",
    "gitDecoration.addedResourceForeground": "#65bfa9",
    "gitDecoration.modifiedResourceForeground": "#c9ad68",
    "gitDecoration.deletedResourceForeground": "#cf8176",
    "gitDecoration.untrackedResourceForeground": "#46a992",
    "gitDecoration.ignoredResourceForeground": "#53616b",
    "notifications.background": "#1f1f1f",
    "notifications.foreground": "#ded8cf",
    "notificationToast.border": "#2f353a"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#7d858c", "fontStyle": "italic" } },
    { "scope": ["keyword", "storage.type", "storage.modifier"], "settings": { "foreground": "#c96f8d", "fontStyle": "bold" } },
    { "scope": ["keyword.control.return", "keyword.control.flow"], "settings": { "foreground": "#c96f8d", "fontStyle": "bold" } },
    { "scope": ["entity.name.function", "support.function", "meta.function-call"], "settings": { "foreground": "#b58cff" } },
    { "scope": ["variable.function", "support.function.builtin"], "settings": { "foreground": "#56c5cf" } },
    { "scope": ["entity.name.type", "support.type", "support.class", "entity.name.class"], "settings": { "foreground": "#6fd8bd" } },
    { "scope": ["entity.name.namespace", "entity.name.module"], "settings": { "foreground": "#56c5cf" } },
    { "scope": ["string", "constant.other.symbol"], "settings": { "foreground": "#8fa0a8" } },
    { "scope": ["constant.numeric", "constant.language.boolean"], "settings": { "foreground": "#7f95a3" } },
    { "scope": ["constant.language", "constant.character.escape"], "settings": { "foreground": "#56c5cf" } },
    { "scope": ["variable", "meta.definition.variable"], "settings": { "foreground": "#ded8cf" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#aeb7bc" } },
    { "scope": ["variable.other.property", "support.variable.property", "meta.object-literal.key"], "settings": { "foreground": "#1f8f9a" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#56c5cf" } },
    { "scope": ["punctuation", "meta.brace", "meta.delimiter"], "settings": { "foreground": "#53616b" } },
    { "scope": ["keyword.operator", "storage.type.function.arrow"], "settings": { "foreground": "#b58cff" } },
    { "scope": ["invalid", "invalid.illegal"], "settings": { "foreground": "#cf8176", "fontStyle": "bold" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#b58cff", "fontStyle": "bold" } },
    { "scope": ["markup.italic"], "settings": { "foreground": "#a4adb2", "fontStyle": "italic" } },
    { "scope": ["markup.bold"], "settings": { "foreground": "#d8d3ca", "fontStyle": "bold" } },
    { "scope": ["markup.inline.raw", "markup.fenced_code.block"], "settings": { "foreground": "#65bfa9" } },
    { "scope": ["markup.underline.link"], "settings": { "foreground": "#58aeba", "fontStyle": "underline" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#65bfa9" } },
    { "scope": ["markup.changed"], "settings": { "foreground": "#7f95a3" } },
    { "scope": ["markup.deleted"], "settings": { "foreground": "#cf8176" } }
  ],
  "semanticTokenColors": {
    "namespace": "#56c5cf",
    "type": "#6fd8bd",
    "class": "#6fd8bd",
    "enum": "#6fd8bd",
    "interface": "#2fbf9f",
    "struct": "#6fd8bd",
    "typeParameter": "#2fbf9f",
    "parameter": "#aeb7bc",
    "variable": "#ded8cf",
    "property": "#1f8f9a",
    "enumMember": "#7f95a3",
    "event": "#b58cff",
    "function": "#b58cff",
    "method": "#2fbf9f",
    "macro": "#b58cff",
    "keyword": "#c96f8d",
    "comment": { "foreground": "#7d858c", "fontStyle": "italic" },
    "string": "#8fa0a8",
    "number": "#7f95a3",
    "regexp": "#56c5cf",
    "operator": "#b58cff",
    "decorator": "#56c5cf"
  }
}
